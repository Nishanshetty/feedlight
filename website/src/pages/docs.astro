      <span class="font-headline text-xs font-bold tracking-[0.25em] text-muted uppercase">FEEDLIGHT</span>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-xs text-muted transition-colors hover:text-cream tracking-wide">
        Open source on GitHub
      </a>
    </div>
  </footer>
</Layout>

